# =============================================================================
# SushiChain — Environment Variables Reference
# =============================================================================
# Copy this file and fill in values for the desired environment:
#   cp .env.example .env.development   # for local dev (PostgreSQL via Docker)
#   cp .env.example .env.staging       # for staging
#   cp .env.example .env.production    # for production
# =============================================================================

# ── Application ────────────────────────────────────────────────────────────
NODE_ENV=development                    # development | staging | production
NEXT_PUBLIC_APP_URL=http://localhost:3000
BRAND_DOMAIN=localhost                 # sushichain.ua (prod) or staging.sushichain.ua (staging)

# ── Database ───────────────────────────────────────────────────────────────
# All environments use PostgreSQL. The canonical schema is prisma/schema.prisma.
# Local dev uses a Docker PostgreSQL (docker-compose.dev.yml).
DATABASE_URL="postgresql://sushichain:sushichain_dev@localhost:5432/sushichain_dev?schema=public"
# DIRECT_URL=                       # Optional: direct connection for migrations (bypasses connection pooler)

# ── JWT Authentication ──────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-strong-secret-at-least-32-characters
JWT_REFRESH_SECRET=change-me-to-another-strong-secret-at-least-32-characters

# ── Payments (LiqPay) ───────────────────────────────────────────────────────
PAYMENT_PROVIDER=liqpay_sandbox         # liqpay | liqpay_sandbox
LIQPAY_PUBLIC_KEY=sandbox_public_key
LIQPAY_PRIVATE_KEY=sandbox_private_key

# ── Telegram Bot (optional — for customer notifications) ─────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=-1001234567890

# ── Alerting (optional — error notifications) ───────────────────────────────
# TELEGRAM_ALERT_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_ALERT_CHAT_ID=-1001234567890
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=debug                         # debug | info | warn | error

# ── NextAuth (optional) ────────────────────────────────────────────────────
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=change-me