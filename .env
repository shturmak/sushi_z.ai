DATABASE_URL=file:/home/z/my-project/db/custom.db

# ── Payment Provider ──────────────────────────────────────
# Set to "liqpay" (default), "fondy", "stripe", etc.
PAYMENT_PROVIDER=liqpay

# LiqPay credentials (request sandbox keys at https://www.liqpay.ua)
LIQPAY_PUBLIC_KEY=sandbox_public_key
LIQPAY_PRIVATE_KEY=sandbox_private_key
LIQPAY_IS_TEST=true

# Optional: override the auto-detected webhook callback URL
# LIQPAY_SERVER_URL=https://your-domain.com/api/payments/webhook/liqpay
