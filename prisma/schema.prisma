// ============================================================
// SushiChain — Omnichannel Food Ordering System
// CANONICAL Prisma Schema (PostgreSQL)
// ============================================================
// This is the SINGLE source of truth for the database schema.
// All environments (dev, staging, production) use PostgreSQL.
// Migrations are generated from this file only.
//
// For quick SQLite prototyping, see prisma/schema.sqlite.prisma (dev-only).
// That file is a convenience copy — NOT the source of truth.
//
// RULES:
//   1. All schema changes go HERE first.
//   2. Run `bun run db:migrate` to create a migration against local PG.
//   3. Review the generated SQL before committing.
//   4. `prisma migrate deploy` applies migrations on staging/prod.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
//  BRANDS (white-label tenants)
// ──────────────────────────────────────────────

model Brand {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  logoUrl         String?
  primaryColor    String   @default("#e11d48")
  secondaryColor  String?
  accentColor     String?
  heroBannerUrl   String?
  promoBannerUrls Json?    // JSON array of banner URLs
  description     String?
  slogan          String?
  isActive        Boolean  @default(true)
  currency        String   @default("UAH")
  currencySymbol  String   @default("₴")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branches         Branch[]
  categories       Category[]
  products         Product[]
  promotions       Promotion[]
  orders           Order[]
  carts            Cart[]
  loyaltyAccounts  LoyaltyAccount[]
  users            User[]
  reviews          Review[]
  favoriteProducts FavoriteProduct[]
  feedbacks        Feedback[]
  campaigns        Campaign[]
  couriers         Courier[]
  menuTranslations MenuTranslation[]
  settings         BrandSettings?

  @@map("brands")
}

// ──────────────────────────────────────────────
//  AUTH & USERS
// ──────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  phone        String?   @unique
  email        String?   @unique
  passwordHash String
  firstName    String    @default("")
  lastName     String    @default("")
  role         String    @default("customer") // customer | admin | manager | super_admin
  avatarUrl    String?
  isActive     Boolean   @default(true)
  brandId      String?   // admin's brand (null for super_admin)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  addresses        UserAddress[]
  carts            Cart[]
  orders           Order[]
  sessions         UserSession[]
  loyaltyAccounts  LoyaltyAccount[]
  favoriteProducts FavoriteProduct[]
  reviews          Review[]
  feedbacks        Feedback[]
  brand            Brand?  @relation(fields: [brandId], references: [id], onDelete: SetNull)

  @@index([brandId])
  @@map("users")
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  deviceInfo   String?   // e.g. "iPhone 15 / iOS 17"
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

model UserAddress {
  id        String   @id @default(cuid())
  userId    String
  label     String?   // "Home", "Work"
  street    String
  building  String?
  apartment String?
  floor     String?
  entrance  String?
  comment   String?
  latitude  Float?
  longitude Float?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_addresses")
}

// ──────────────────────────────────────────────
//  BRANCHES
// ──────────────────────────────────────────────

model Branch {
  id              String   @id @default(cuid())
  brandId         String
  name            String
  slug            String
  address         String
  phone           String?
  email           String?
  latitude        Float?
  longitude       Float?
  isOpen          Boolean  @default(true)
  workSchedule    Json?    // {"mon":"09:00-22:00",...}
  description     String?
  imageUrl        String?
  sortOrder       Int      @default(0)
  autoConfirm     Boolean  @default(false)
  acceptingOrders Boolean  @default(true)
  minOrderAmount  Float    @default(0)
  prepTimeMinutes Int      @default(30)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  brand         Brand         @relation(fields: [brandId], references: [id], onDelete: Cascade)
  categories    Category[]
  orders        Order[]
  deliveryZones DeliveryZone[]
  products      Product[]
  carts         Cart[]
  feedbacks     Feedback[]

  @@unique([brandId, slug])
  @@index([brandId])
  @@map("branches")
}

model DeliveryZone {
  id               String   @id @default(cuid())
  branchId         String
  name             String
  description      String?
  minOrder         Float    @default(0)
  deliveryFee      Float    @default(0)
  estimatedMinutes Int      @default(30)
  polygonData      Json?    // polygon coordinates
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@map("delivery_zones")
}

// ──────────────────────────────────────────────
//  MENU
// ──────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  brandId     String
  branchId    String?  // null = brand-wide category
  name        String
  slug        String
  description String?
  imageUrl    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand   Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  branch  Branch?  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([brandId, branchId, slug])
  @@index([brandId])
  @@index([branchId])
  @@map("categories")
}

model Product {
  id          String   @id @default(cuid())
  brandId     String
  categoryId  String
  branchId    String?  // null = available at all branches
  name        String
  slug        String
  description String?
  imageUrl    String?
  price       Float
  weight      String?  // e.g. "350г"
  calories    Int?
  tags        String[] // ["роли","сети","вегетарианское"]
  allergens   String[] // ["глютен","молоко","орехи"]
  isVegetarian Boolean  @default(false)
  isAvailable Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand            Brand               @relation(fields: [brandId], references: [id], onDelete: Cascade)
  category         Category            @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  branch           Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  optionGroups     ProductOptionGroup[]
  cartItems        CartItem[]
  orderItems       OrderItem[]
  favoriteProducts FavoriteProduct[]
  reviews          Review[]

  @@index([brandId])
  @@index([categoryId])
  @@index([branchId])
  @@index([isAvailable])
  @@map("products")
}

model ProductOptionGroup {
  id         String  @id @default(cuid())
  productId  String
  name       String  // e.g. "Size", "Spiciness"
  isRequired Boolean @default(false)
  maxChoices Int     @default(1) // 0 = unlimited
  sortOrder  Int     @default(0)
  createdAt  DateTime @default(now())

  product Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  options ProductOption[]

  @@index([productId])
  @@map("product_option_groups")
}

model ProductOption {
  id         String  @id @default(cuid())
  groupId    String
  name       String  // e.g. "Large +80грн"
  priceDelta Float   @default(0) // additional cost
  sortOrder  Int     @default(0)

  group ProductOptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@map("product_options")
}

model FavoriteProduct {
  id        String   @id @default(cuid())
  userId    String
  brandId   String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand   Brand   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([brandId])
  @@map("favorite_products")
}

// ──────────────────────────────────────────────
//  CART (server-side, per user per brand)
// ──────────────────────────────────────────────

model Cart {
  id        String   @id @default(cuid())
  userId    String
  brandId   String
  branchId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand  Brand      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  branch Branch     @relation(fields: [branchId], references: [id])
  items  CartItem[]

  @@unique([userId, brandId])
  @@index([userId])
  @@index([branchId])
  @@map("carts")
}

model CartItem {
  id              String   @id @default(cuid())
  cartId          String
  productId       String
  quantity        Int      @default(1)
  selectedOptions Json?    // [{optionId, groupId, name, priceDelta}, ...]
  totalPrice      Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([cartId])
  @@map("cart_items")
}

// ──────────────────────────────────────────────
//  ORDERS
// ──────────────────────────────────────────────

enum OrderType {
  delivery
  pickup
}

enum OrderStatus {
  new
  confirmed
  cooking
  ready
  delivering
  completed
  cancelled
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique // human-readable: #1042
  userId          String
  brandId         String
  branchId        String
  type            OrderType
  status          OrderStatus @default(new)

  // Delivery details
  addressSnapshot Json?       // JSON of delivery address
  deliveryFee     Float       @default(0)

  // Totals
  subtotal        Float
  discount        Float       @default(0)
  total           Float

  // Customer note
  note            String?

  // Promotion
  promotionId     String?
  promotionCode   String?

  // Loyalty
  bonusUsed       Float       @default(0)

  // Estimated
  estimatedMinutes Int?

  // Scheduled delivery / pre-order
  scheduledAt     DateTime?

  // Timeline
  confirmedAt     DateTime?
  cookingAt       DateTime?
  readyAt         DateTime?
  deliveringAt    DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user              User              @relation(fields: [userId], references: [id])
  brand             Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  branch            Branch            @relation(fields: [branchId], references: [id])
  promotion         Promotion?        @relation(fields: [promotionId], references: [id])
  items             OrderItem[]
  payments          Payment[]
  reviews           Review[]
  feedbacks         Feedback[]
  deliveryAssignment DeliveryAssignment?

  @@index([userId])
  @@index([brandId])
  @@index([branchId])
  @@index([status])
  @@index([promotionId])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  productId       String
  productName     String   // snapshot
  productPrice    Float    // snapshot
  quantity        Int
  selectedOptions Json?    // JSON snapshot
  totalPrice      Float
  createdAt       DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// ──────────────────────────────────────────────
//  PAYMENTS
// ──────────────────────────────────────────────

enum PaymentStatus {
  pending
  processing
  succeeded
  failed
  refunded
}

enum PaymentMethod {
  card
  cash
  bonus
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String
  method          PaymentMethod
  status          PaymentStatus @default(pending)
  amount          Float
  providerTxId    String?       // external payment provider transaction ID
  providerPayload Json?         // full webhook payload
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("payments")
}

// ──────────────────────────────────────────────
//  PROMOTIONS
// ──────────────────────────────────────────────

enum PromotionType {
  percentage    // 20% off
  fixed         // 50грн off
  free_delivery // no delivery fee
  bonus         // +100 bonus points
}

enum PromotionStatus {
  active
  inactive
  expired
}

model Promotion {
  id          String         @id @default(cuid())
  code        String?        // null = auto-applied
  name        String
  description String?
  type        PromotionType
  value       Float          // percentage value, fixed amount, etc.
  minOrder    Float          @default(0)
  maxUses     Int?           // null = unlimited
  usedCount   Int            @default(0)
  startDate   DateTime
  endDate     DateTime
  status      PromotionStatus @default(active)
  brandId     String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  brand  Brand   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([brandId, code])
  @@index([brandId])
  @@map("promotions")
}

// ──────────────────────────────────────────────
//  LOYALTY
// ──────────────────────────────────────────────

enum LoyaltyTransactionType {
  earned     // from completing order
  spent      // used for payment
  adjusted   // manual admin adjustment
  expired
}

model LoyaltyAccount {
  id        String              @id @default(cuid())
  userId    String
  brandId   String
  balance   Float               @default(0)
  lifetime  Float               @default(0)
  tier      String              @default("bronze") // bronze, silver, gold
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand        Brand                @relation(fields: [brandId], references: [id], onDelete: Cascade)
  transactions LoyaltyTransaction[]

  @@unique([userId, brandId])
  @@index([userId])
  @@index([brandId])
  @@map("loyalty_accounts")
}

model LoyaltyTransaction {
  id             String                   @id @default(cuid())
  accountId      String
  type           LoyaltyTransactionType
  amount         Float
  balanceAfter   Float
  description    String?
  relatedOrderId String?
  createdAt      DateTime                 @default(now())

  account LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([relatedOrderId])
  @@map("loyalty_transactions")
}

// ──────────────────────────────────────────────
//  REVIEWS
// ──────────────────────────────────────────────

model Review {
  id          String   @id @default(cuid())
  userId      String
  brandId     String
  productId   String?
  orderId     String
  rating      Int      // 1-5
  comment     String?
  isApproved  Boolean  @default(false) // admin moderation
  isAdminReply String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  brand   Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  product  Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  order    Order    @relation(fields: [orderId], references: [id])

  @@index([userId])
  @@index([brandId])
  @@index([productId])
  @@index([orderId])
  @@map("reviews")
}

// ──────────────────────────────────────────────
//  FEEDBACK / SUPPORT
// ──────────────────────────────────────────────

enum FeedbackType {
  order_issue
  general
  suggestion
  complaint
}

enum FeedbackStatus {
  new
  in_progress
  resolved
  closed
}

model Feedback {
  id          String         @id @default(cuid())
  userId      String?
  brandId     String
  branchId    String?
  orderId     String?
  type        FeedbackType   @default(general)
  status      FeedbackStatus @default(new)
  subject     String?
  message     String
  contactInfo String?        // phone/email provided by user
  adminReply  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  brand  Brand   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  order  Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([brandId])
  @@index([orderId])
  @@map("feedbacks")
}

// ──────────────────────────────────────────────
//  CAMPAIGNS & WIN-BACK
// ──────────────────────────────────────────────

enum CampaignType {
  win_back
  promo
  notification
}

enum CampaignStatus {
  draft
  active
  paused
  completed
}

model Campaign {
  id            String         @id @default(cuid())
  brandId       String
  name          String
  type          CampaignType
  status        CampaignStatus @default(draft)
  subject       String
  body          String         // message body (template, may include {name}, {bonusBalance}, etc.)
  targetSegment String?        // all, new, inactive_7d, inactive_14d, inactive_30d, high_value
  channel       String         @default("telegram") // telegram, email, sms, push
  sentCount     Int            @default(0)
  openedCount   Int            @default(0)
  clickedCount  Int            @default(0)
  scheduledAt   DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  brand    Brand            @relation(fields: [brandId], references: [id], onDelete: Cascade)
  messages CampaignMessage[]

  @@index([brandId])
  @@index([status])
  @@map("campaigns")
}

model CampaignMessage {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  channel    String
  status     String   @default("pending") // pending, sent, failed, opened, clicked
  sentAt     DateTime?
  openedAt   DateTime?
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([userId])
  @@map("campaign_messages")
}

// ──────────────────────────────────────────────
//  COURIERS & DELIVERY ASSIGNMENTS
// ──────────────────────────────────────────────

model Courier {
  id        String   @id @default(cuid())
  brandId   String
  name      String
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand              Brand              @relation(fields: [brandId], references: [id], onDelete: Cascade)
  deliveryAssignments DeliveryAssignment[]

  @@index([brandId])
  @@map("couriers")
}

model DeliveryAssignment {
  id          String   @id @default(cuid())
  orderId     String   @unique
  courierId   String
  status      String   @default("assigned") // assigned, picked_up, delivered
  assignedAt  DateTime @default(now())
  pickedUpAt  DateTime?
  deliveredAt DateTime?
  createdAt   DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id])
  courier Courier @relation(fields: [courierId], references: [id], onDelete: Cascade)

  @@index([courierId])
  @@map("delivery_assignments")
}

// ──────────────────────────────────────────────
//  MENU TRANSLATIONS
// ──────────────────────────────────────────────

model MenuTranslation {
  id          String   @id @default(cuid())
  brandId     String
  locale      String   // 'uk', 'ru', 'en'
  entityType  String   // 'Product', 'Category'
  entityId    String   // the ID of the Product or Category
  name        String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, locale, entityType, entityId])
  @@index([brandId])
  @@map("menu_translations")
}

// ──────────────────────────────────────────────
//  BRAND SETTINGS / FEATURE FLAGS
// ──────────────────────────────────────────────

model BrandSettings {
  id                    String   @id @default(cuid())
  brandId               String   @unique
  enableGuestOrders     Boolean  @default(true)
  enableScheduledOrders Boolean  @default(true)
  enableLoyalty         Boolean  @default(true)
  enableReviews         Boolean  @default(true)
  enableDelivery        Boolean  @default(true)
  enablePickup          Boolean  @default(true)
  enablePromotions      Boolean  @default(true)
  enableRecommendations Boolean  @default(true)
  enableSearch          Boolean  @default(true)
  enableFavorites       Boolean  @default(true)
  requirePhone          Boolean  @default(true)
  requireAddress        Boolean  @default(true)
  showTips              Boolean  @default(false)
  enableApplePay        Boolean  @default(true)
  enableDeliveryFeatures Boolean @default(true)
  enableCampaigns       Boolean  @default(true)
  enableTranslations    Boolean  @default(false)
  loyaltyRate           Float    @default(5)
  loyaltyMinSpend       Float    @default(0)
  loyaltyMaxBonusPayment Float  @default(50)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@map("brand_settings")
}